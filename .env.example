# News Pilot — Environment Configuration

# Required: OpenAI (news translation)
OPENAI_API_KEY=sk-...

# Required: Sarvam AI TTS (Bulbul v3 — best Indian language voices)
# Get key from https://dashboard.sarvam.ai
SARVAM_API_KEY=

# Optional Sarvam settings
# SARVAM_SPEAKER=shubh
# SARVAM_PACE=0.92
# SARVAM_MODEL=bulbul:v3

# Fallback for Maithili & other langs not in Sarvam TTS (optional)
# BHASHINI_API_KEY=

# Fallback for English (optional — Sarvam en-IN works too)
# ELEVENLABS_API_KEY=sk-...
